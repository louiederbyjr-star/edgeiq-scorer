# EdgeIQ MVP — Environment Variables
# Copy this to .env and fill in your real keys. Never commit .env to git.

# 1. The Odds API — free tier at https://the-odds-api.com
#    Free: 500 requests/month (more than enough for daily runs)
ODDS_API_KEY=

# 2. Supabase — free tier at https://supabase.com
#    Create a project, then go to Settings > API
SUPABASE_URL=
SUPABASE_KEY=
